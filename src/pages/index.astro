---
import BaseLayout from '../layouts/BaseLayout.astro';
import { listMultipliers, listTags, parseTags, type Multiplier, type Tag } from '../lib/db';

// SSR: rendered on every request so the list reflects the DB without a redeploy.
export const prerender = false;

const { env } = Astro.locals.runtime;

let multipliers: Multiplier[] = [];
let allTags: Tag[] = [];
let pillars = new Set<string>();
let error: string | null = null;

try {
  const [mult, tags] = await Promise.all([listMultipliers(env), listTags(env)]);
  multipliers = mult;
  allTags = tags;
  // Pillar tags (Intent/Leverage/Judgment) render UPPERCASE to set them apart
  // from the lowercase layer tags.
  pillars = new Set(tags.filter((t) => t.group === 'pillar').map((t) => t.name));
} catch (e) {
  // Don't 500 the page on a DB/credentials hiccup — show a notice instead.
  error = e instanceof Error ? e.message : 'Unknown error';
}

// ---- Tag filter (server-side, URL-driven) --------------------------------
// The selector is just a list of links: each toggles its own slug in the
// `?tags=` query param. Filtering is AND — a multiplier must carry every
// selected tag. Canonical order (layers, then pillars) keeps the URL stable.
const tagOrder = new Map(allTags.map((t, i) => [t.name, i]));
const selectedSet = new Set(
  parseTags(Astro.url.searchParams.get('tags')).filter((t) => tagOrder.has(t))
);
const selected = [...selectedSet].sort(
  (a, b) => (tagOrder.get(a) ?? 0) - (tagOrder.get(b) ?? 0)
);

/** URL that toggles `tag` on/off, preserving the rest of the selection. */
function tagHref(tag: string): string {
  const next = new Set(selectedSet);
  next.has(tag) ? next.delete(tag) : next.add(tag);
  const list = [...next].sort(
    (a, b) => (tagOrder.get(a) ?? 0) - (tagOrder.get(b) ?? 0)
  );
  return list.length ? `/?tags=${list.join(',')}` : '/';
}

const visible =
  selected.length === 0
    ? multipliers
    : multipliers.filter((m) => {
        const tags = parseTags(m.tags);
        return selected.every((t) => tags.includes(t));
      });

/** Strip the scheme for a tidier visible link label. */
function hostLabel(url: string): string {
  return url.replace(/^https?:\/\//, '').replace(/\/$/, '');
}
---

<BaseLayout>
  <p class="page-tag">[ Multipliers ]</p>
  <h1>Multipliers</h1>
  <p class="lead">
    A living list of multipliers — the reusable artifacts, practices, and methods
    that raise what one mind can build. Curated, and growing.
  </p>

  {
    error ? (
      <div class="notice error">
        <p>Couldn't load the list right now. ({error})</p>
      </div>
    ) : multipliers.length === 0 ? (
      <div class="notice">
        <p>No multipliers yet — the list is just getting started.</p>
      </div>
    ) : (
      <>
        <div class="tagbar" role="group" aria-label="Filter by tag">
          <span class="label">filter</span>
          {allTags.map((t) => (
            <a
              href={tagHref(t.name)}
              class={`tagfilter ${pillars.has(t.name) ? 'pillar' : 'layer'} ${
                selectedSet.has(t.name) ? 'is-selected' : ''
              }`}
              aria-pressed={selectedSet.has(t.name)}
              title={t.description ?? undefined}
            >
              {t.name}
            </a>
          ))}
        </div>
        <p class="count">
          {selected.length > 0
            ? `${visible.length} of ${multipliers.length} multipliers`
            : `${multipliers.length} multiplier${multipliers.length === 1 ? '' : 's'}`}
        </p>
        {visible.length === 0 ? (
          <div class="notice">
            <p>No multipliers match every selected tag. Remove one to widen the list.</p>
          </div>
        ) : (
        <ul class="mlist">
          {visible.map((m) => (
            <li class="m">
              <h2 class="m-title">
                <a href={m.url} rel="noopener" target="_blank">
                  {m.title}
                </a>
                <span class="arrow">↗</span>
              </h2>
              <p class="m-desc">{m.description}</p>
              {
                parseTags(m.tags).length > 0 && (
                  <div class="m-tags">
                    {parseTags(m.tags).map((tag) => (
                      <span class={`tag ${pillars.has(tag) ? 'pillar' : 'layer'}`}>
                        {tag}
                      </span>
                    ))}
                  </div>
                )
              }
              <div class="m-meta">
                <span>
                  <span class="label">link</span>
                  <a href={m.url} rel="noopener" target="_blank">
                    {hostLabel(m.url)}
                  </a>
                </span>
                {m.more_info_url && (
                  <span>
                    <span class="label">more</span>
                    <a href={m.more_info_url} rel="noopener" target="_blank">
                      {hostLabel(m.more_info_url)}
                    </a>
                  </span>
                )}
                {m.author_github && (
                  <span>
                    <span class="label">by</span>
                    <a
                      href={`https://github.com/${m.author_github}`}
                      rel="noopener"
                      target="_blank"
                    >
                      @{m.author_github}
                    </a>
                  </span>
                )}
                {!m.author_github && m.author_email && (
                  <span>
                    <span class="label">by</span>
                    <a href={`mailto:${m.author_email}`}>{m.author_email}</a>
                  </span>
                )}
              </div>
            </li>
          ))}
        </ul>
        )}
      </>
    )
  }
</BaseLayout>
